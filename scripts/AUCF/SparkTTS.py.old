import websocket
import datetime
import hashlib
import base64
import hmac
import json
from urllib.parse import urlencode
import time
import ssl
from wsgiref.handlers import format_date_time
from datetime import datetime
from time import mktime
import _thread as thread
import os
import sys
import argparse
import struct

STATUS_FIRST_FRAME = 0  # 第一帧的标识
STATUS_CONTINUE_FRAME = 1  # 中间帧标识
STATUS_LAST_FRAME = 2  # 最后一帧的标识


class Ws_Param(object):
    # 初始化
    def __init__(self, APPID, APIKey, APISecret, Text, output_file, voice="x4_yezi"):
        self.APPID = APPID
        self.APIKey = APIKey
        self.APISecret = APISecret
        self.Text = Text
        self.output_file = output_file

        # 公共参数(common)
        self.CommonArgs = {"app_id": self.APPID}
        # 业务参数(business)，更多个性化参数可在官网查看
        # 修改aue参数为raw以输出PCM格式，后续会转换为WAV
        self.BusinessArgs = {"aue": "raw", "auf": "audio/L16;rate=16000", "vcn": voice, "tte": "utf8"}
        self.Data = {"status": 2, "text": str(base64.b64encode(self.Text.encode('utf-8')), "UTF8")}
        # 使用小语种须使用以下方式，此处的unicode指的是 utf16小端的编码方式，即"UTF-16LE""
        # self.Data = {"status": 2, "text": str(base64.b64encode(self.Text.encode('utf-16')), "UTF8")}

    # 生成url
    def create_url(self):
        url = 'wss://tts-api.xfyun.cn/v2/tts'
        # 生成RFC1123格式的时间戳
        now = datetime.now()
        date = format_date_time(mktime(now.timetuple()))

        # 拼接字符串
        signature_origin = "host: " + "ws-api.xfyun.cn" + "\n"
        signature_origin += "date: " + date + "\n"
        signature_origin += "GET " + "/v2/tts " + "HTTP/1.1"
        # 进行hmac-sha256进行加密
        signature_sha = hmac.new(self.APISecret.encode('utf-8'), signature_origin.encode('utf-8'),
                                 digestmod=hashlib.sha256).digest()
        signature_sha = base64.b64encode(signature_sha).decode(encoding='utf-8')

        authorization_origin = "api_key=\"%s\", algorithm=\"%s\", headers=\"%s\", signature=\"%s\"" % (
            self.APIKey, "hmac-sha256", "host date request-line", signature_sha)
        authorization = base64.b64encode(authorization_origin.encode('utf-8')).decode(encoding='utf-8')
        # 将请求的鉴权参数组合为字典
        v = {
            "authorization": authorization,
            "date": date,
            "host": "ws-api.xfyun.cn"
        }
        # 拼接鉴权参数，生成url
        url = url + '?' + urlencode(v)
        return url


def write_wav_header(file, audio_data_size, sample_rate=16000, num_channels=1, bits_per_sample=16):
    """写入WAV文件头"""
    # WAV文件头结构
    file.write(b'RIFF')
    file.write(struct.pack('<I', 36 + audio_data_size))  # 文件总长度-8
    file.write(b'WAVE')
    file.write(b'fmt ')
    file.write(struct.pack('<I', 16))  # fmt块长度
    file.write(struct.pack('<H', 1))  # 音频格式（PCM）
    file.write(struct.pack('<H', num_channels))  # 声道数
    file.write(struct.pack('<I', sample_rate))  # 采样率
    file.write(struct.pack('<I', sample_rate * num_channels * bits_per_sample // 8))  # 字节率
    file.write(struct.pack('<H', num_channels * bits_per_sample // 8))  # 块对齐
    file.write(struct.pack('<H', bits_per_sample))  # 位深度
    file.write(b'data')
    file.write(struct.pack('<I', audio_data_size))  # 数据块长度


def on_message(ws, message):
    try:
        message = json.loads(message)
        code = message["code"]
        sid = message["sid"]
        audio = message["data"]["audio"]
        audio = base64.b64decode(audio)
        status = message["data"]["status"]

        if status == 2:
            print("WebSocket connection closed")
            ws.close()
        if code != 0:
            errMsg = message["message"]
            print("Error: sid:%s call error:%s code is:%s" % (sid, errMsg, code))
            sys.exit(1)  # 退出并返回错误码
        else:
            # 将PCM数据添加到列表
            ws.audio_data.append(audio)
            # 如果是最后一帧，则写入WAV文件
            if status == 2:
                # 计算总音频数据大小
                total_audio_size = sum(len(data) for data in ws.audio_data)

                # 写入WAV文件
                with open(ws.output_file, 'wb') as f:
                    # 先写入WAV文件头
                    write_wav_header(f, total_audio_size)
                    # 写入所有PCM数据
                    for data in ws.audio_data:
                        f.write(data)

                print(f"TTS completed. Output file: {ws.output_file}")

    except Exception as e:
        print("Error parsing message:", e)
        sys.exit(1)


# 收到websocket错误的处理
def on_error(ws, error):
    print("WebSocket error:", error)
    sys.exit(1)


# 收到websocket关闭的处理
def on_close(ws):
    print("WebSocket connection closed")


# 收到websocket连接建立的处理
def on_open(ws):
    def run(*args):
        d = {"common": ws.wsParam.CommonArgs,
             "business": ws.wsParam.BusinessArgs,
             "data": ws.wsParam.Data,
             }
        d = json.dumps(d)
        print("Sending text data...")
        ws.send(d)
        # 初始化音频数据列表
        ws.audio_data = []
        # 如果输出文件已存在，则删除
        if os.path.exists(ws.output_file):
            os.remove(ws.output_file)

    thread.start_new_thread(run, ())


def main():
    # 设置命令行参数
    parser = argparse.ArgumentParser(description='Xunfei TTS WebSocket API Demo')
    parser.add_argument('--appid', required=True, help='App ID')
    parser.add_argument('--api_key', required=True, help='API Key')
    parser.add_argument('--api_secret', required=True, help='API Secret')
    parser.add_argument('--text', required=True, help='Text to synthesize')
    parser.add_argument('--output', required=True, help='Output file path (WAV)')
    parser.add_argument('--voice', default='x4_yezi', help='Voice name (default: x4_yezi)')

    args = parser.parse_args()

    # 确保输出文件扩展名为.wav
    if not args.output.lower().endswith('.wav'):
        args.output += '.wav'

    # 创建参数对象
    wsParam = Ws_Param(APPID=args.appid,
                       APIKey=args.api_key,
                       APISecret=args.api_secret,
                       Text=args.text,
                       output_file=args.output,
                       voice=args.voice)

    # 设置WebSocket
    websocket.enableTrace(False)
    wsUrl = wsParam.create_url()

    # 创建WebSocketApp实例并添加自定义属性
    ws = websocket.WebSocketApp(wsUrl,
                                on_message=on_message,
                                on_error=on_error,
                                on_close=on_close)

    # 添加自定义属性以便在回调中访问
    ws.wsParam = wsParam
    ws.output_file = args.output

    ws.on_open = on_open
    ws.run_forever(sslopt={"cert_reqs": ssl.CERT_NONE})


if __name__ == "__main__":
    main()
