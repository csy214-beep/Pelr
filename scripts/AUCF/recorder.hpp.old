#ifndef RECORDER_HPP
#define RECORDER_HPP

#include <fstream>
#include <windows.h>
#include <iostream>
#include <string>
#include <QDebug>
#include <ctime>
#include <sys/stat.h>
#include <io.h>
using namespace std;

class Recorder {
public:
    QString getFileCreationTimeWindows(const string &filename) {
        struct _stat stat_buffer;
        int result = _stat(filename.c_str(), &stat_buffer);

        if (result != 0) {
            qDebug() << "无法获取文件时间信息: " << GetLastError();
            return QString();
        }

        struct tm tmStruct;
        char timeChar[26];

        localtime_s(&tmStruct, &stat_buffer.st_ctime);
        strftime(timeChar, sizeof(timeChar), "%Y-%m-%d %H:%M:%S", &tmStruct);
        qDebug() << "创建时间 : " << timeChar;
        return QString(timeChar);

        localtime_s(&tmStruct, &stat_buffer.st_mtime);
        strftime(timeChar, sizeof(timeChar), "%Y-%m-%d %H:%M:%S", &tmStruct);
        qDebug() << "修改时间: " << timeChar;

        localtime_s(&tmStruct, &stat_buffer.st_atime);
        strftime(timeChar, sizeof(timeChar), "%Y-%m-%d %H:%M:%S", &tmStruct);
        qDebug() << "访问时间: " << timeChar;

        qDebug() << "文件大小: " << stat_buffer.st_size << " 字节";
    }

    // 写入两个 long long 类型的数到二进制文件
    void writeBinaryData(const std::string &filename, long num1, long num2) {
        std::ofstream outFile(filename, std::ios::binary);
        if (!outFile) {
            qDebug() << "无法打开文件 " << QString::fromStdString(filename) << " 进行写操作";
            return;
        }
        outFile.write(reinterpret_cast<const char *>(&num1), sizeof(num1));
        outFile.write(reinterpret_cast<const char *>(&num2), sizeof(num2));
        outFile.close();
        if (!outFile) {
            qDebug() << "写入文件 " << QString::fromStdString(filename) << " 失败";
        }
    }

    // 从二进制文件读取两个 long long 类型的数
    void readBinaryData(const std::string &filename, long &num1, long &num2) {
        std::ifstream inFile(filename, std::ios::binary);
        if (!inFile) {
            qDebug() << "无法打开文件 " << QString::fromStdString(filename) << " 进行读操作";
            return;
        }
        inFile.read(reinterpret_cast<char *>(&num1), sizeof(num1));
        inFile.read(reinterpret_cast<char *>(&num2), sizeof(num2));
        inFile.close();
        if (!inFile) {
            qDebug() << "读取文件 " << QString::fromStdString(filename) << " 失败";
        }
    }
};

#endif // RECORDER_HPP
