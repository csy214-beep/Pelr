LAppModel::LAppModel()
        : LAppModel_Common(), _modelSetting(NULL), _userTimeSeconds(0.0f), _randomActionCooldown(0.0f),
          _extraFileManager(new ExtraFileManager()) // 初始化文件管理器
{
    if (MocConsistencyValidationEnable) {
        _mocConsistency = true;
    }
    if (MotionConsistencyValidationEnable) {
        _motionConsistency = true;
    }

    if (DebugLogEnable) {
        _debugMode = true;
    }

    _idParamAngleX = CubismFramework::GetIdManager()->GetId(ParamAngleX);
    _idParamAngleY = CubismFramework::GetIdManager()->GetId(ParamAngleY);
    _idParamAngleZ = CubismFramework::GetIdManager()->GetId(ParamAngleZ);
    _idParamBodyAngleX = CubismFramework::GetIdManager()->GetId(ParamBodyAngleX);
    _idParamEyeBallX = CubismFramework::GetIdManager()->GetId(ParamEyeBallX);
    _idParamEyeBallY = CubismFramework::GetIdManager()->GetId(ParamEyeBallY);
}

LAppModel::~LAppModel() {
    _renderBuffer.DestroyOffscreenSurface();

    ReleaseMotions();
    ReleaseExpressions();

    for (csmInt32 i = 0; i < _modelSetting->GetMotionGroupCount(); i++) {
        const csmChar *group = _modelSetting->GetMotionGroupName(i);
        ReleaseMotionGroup(group);
    }
    delete (_modelSetting);
    delete _extraFileManager; // 清理文件管理器
}

// 实现设置随机冷却时间的方法
void LAppModel::SetRandomCooldown() {
    // 生成1秒到60秒之间的随机冷却时间
    _randomActionCooldown = (rand() % 59) + 1.0f; // 1-60秒

    if (_debugMode) {
        qDebug() << "Setting random cooldown:" << _randomActionCooldown << "seconds";
    }
}

void LAppModel::LoadAssets(const csmChar *dir, const csmChar *fileName) {
    _modelHomeDir = dir;

    if (_debugMode) {
        LAppPal::PrintLogLn("[APP]load model setting: %s", fileName);
        qDebug() << "load model setting: " << fileName;
    }

    csmSizeInt size;
    const csmString path = csmString(dir) + fileName;

    csmByte *buffer = CreateBuffer(path.GetRawString(), &size);
    ICubismModelSetting *setting = new CubismModelSettingJson(buffer, size);
    DeleteBuffer(buffer, path.GetRawString());

    SetupModel(setting);

    if (_model == NULL) {
        LAppPal::PrintLogLn("Failed to LoadAssets().");
        qDebug() << "Failed to LoadAssets().";
        return;
    }

    CreateRenderer();

    SetupTextures();
}

void LAppModel::SetupModel(ICubismModelSetting *setting) {
    _updating = true;
    _initialized = false;

    _modelSetting = setting;

    csmByte *buffer;
    csmSizeInt size;

    // Cubism Model
    if (strcmp(_modelSetting->GetModelFileName(), "") != 0) {
        csmString path = _modelSetting->GetModelFileName();
        path = _modelHomeDir + path;

        if (_debugMode) {
            LAppPal::PrintLogLn("[APP]create model: %s", setting->GetModelFileName());
            qDebug() << "create model: " << setting->GetModelFileName();
        }

        buffer = CreateBuffer(path.GetRawString(), &size);
        LoadModel(buffer, size, _mocConsistency);
        DeleteBuffer(buffer, path.GetRawString());
    }

    // Expression 表情处理部分
    if (_modelSetting->GetExpressionCount() > 0) {
        // 检查模型设置中是否有表情数据
        const csmInt32 count = _modelSetting->GetExpressionCount(); // 获取表情总数
        for (csmInt32 i = 0; i < count; i++) {
            // 遍历所有表情
            csmString name = _modelSetting->GetExpressionName(i);     // 获取第i个表情的名称
            csmString path = _modelSetting->GetExpressionFileName(i); // 获取第i个表情的文件路径
            path = _modelHomeDir + path;                              // 将相对路径转换为绝对路径（添加模型主目录）

            // 创建缓冲区并读取表情文件内容
            buffer = CreateBuffer(path.GetRawString(), &size);
            // 加载表情数据，返回ACubismMotion对象
            ACubismMotion *motion = LoadExpression(buffer, size, name.GetRawString());

            // 如果表情加载成功
            if (motion) {
                // 检查是否已存在同名表情，如果存在则先删除
                if (_expressions[name] != NULL) {
                    ACubismMotion::Delete(_expressions[name]); // 删除旧的表情对象
                    _expressions[name] = NULL;                 // 将指针置为空
                }
                _expressions[name] = motion; // 将新加载的表情对象存入映射表
            }

            // 删除缓冲区，释放内存
            DeleteBuffer(buffer, path.GetRawString());
        }
    }

    // Physics
    if (strcmp(_modelSetting->GetPhysicsFileName(), "") != 0) {
        csmString path = _modelSetting->GetPhysicsFileName();
        path = _modelHomeDir + path;

        buffer = CreateBuffer(path.GetRawString(), &size);
        LoadPhysics(buffer, size);
        DeleteBuffer(buffer, path.GetRawString());
    }

    // Pose
    if (strcmp(_modelSetting->GetPoseFileName(), "") != 0) {
        csmString path = _modelSetting->GetPoseFileName();
        path = _modelHomeDir + path;

        buffer = CreateBuffer(path.GetRawString(), &size);
        LoadPose(buffer, size);
        DeleteBuffer(buffer, path.GetRawString());
    }

    // EyeBlink
    if (_modelSetting->GetEyeBlinkParameterCount() > 0) {
        _eyeBlink = CubismEyeBlink::Create(_modelSetting);
    }

    // Breath
    {
        _breath = CubismBreath::Create();

        csmVector<CubismBreath::BreathParameterData> breathParameters;

        breathParameters.PushBack(CubismBreath::BreathParameterData(_idParamAngleX, 0.0f, 15.0f, 6.5345f, 0.5f));
        breathParameters.PushBack(CubismBreath::BreathParameterData(_idParamAngleY, 0.0f, 8.0f, 3.5345f, 0.5f));
        breathParameters.PushBack(CubismBreath::BreathParameterData(_idParamAngleZ, 0.0f, 10.0f, 5.5345f, 0.5f));
        breathParameters.PushBack(CubismBreath::BreathParameterData(_idParamBodyAngleX, 0.0f, 4.0f, 15.5345f, 0.5f));
        breathParameters.PushBack(
                CubismBreath::BreathParameterData(CubismFramework::GetIdManager()->GetId(ParamBreath), 0.5f, 0.5f,
                                                  3.2345f,
                                                  0.5f));

        _breath->SetParameters(breathParameters);
    }

    // UserData
    if (strcmp(_modelSetting->GetUserDataFile(), "") != 0) {
        csmString path = _modelSetting->GetUserDataFile();
        path = _modelHomeDir + path;
        buffer = CreateBuffer(path.GetRawString(), &size);
        LoadUserData(buffer, size);
        DeleteBuffer(buffer, path.GetRawString());
    }

    // EyeBlinkIds
    {
        csmInt32 eyeBlinkIdCount = _modelSetting->GetEyeBlinkParameterCount();
        for (csmInt32 i = 0; i < eyeBlinkIdCount; ++i) {
            _eyeBlinkIds.PushBack(_modelSetting->GetEyeBlinkParameterId(i));
        }
    }

    // LipSyncIds
    {
        csmInt32 lipSyncIdCount = _modelSetting->GetLipSyncParameterCount();
        for (csmInt32 i = 0; i < lipSyncIdCount; ++i) {
            _lipSyncIds.PushBack(_modelSetting->GetLipSyncParameterId(i));
        }
    }

    if (_modelSetting == NULL || _modelMatrix == NULL) {
        LAppPal::PrintLogLn("Failed to SetupModel().");
        qDebug() << "Failed to SetupModel()";
        return;
    }

    // Layout
    csmMap<csmString, csmFloat32> layout;
    _modelSetting->GetLayoutMap(layout);
    _modelMatrix->SetupFromLayout(layout);

    _model->SaveParameters();

    for (csmInt32 i = 0; i < _modelSetting->GetMotionGroupCount(); i++) {
        const csmChar *group = _modelSetting->GetMotionGroupName(i);
        PreloadMotionGroup(group);
    }

    _motionManager->StopAllMotions();

    _updating = false;
    _initialized = true;
    LoadExtraFiles();
}

void LAppModel::PreloadMotionGroup(const csmChar *group) {
    const csmInt32 count = _modelSetting->GetMotionCount(group);

    for (csmInt32 i = 0; i < count; i++) {
        // ex) idle_0
        csmString name = Utils::CubismString::GetFormatedString("%s_%d", group, i);
        csmString path = _modelSetting->GetMotionFileName(group, i);
        path = _modelHomeDir + path;

        if (_debugMode) {
//            LAppPal::PrintLogLn("[APP]load motion: %s => [%s_%d] ", path.GetRawString(), group, i);
            qDebug() << "load motion: " << path.GetRawString() << " => [" << group << "_" << i << "]";
        }

        csmByte *buffer;
        csmSizeInt size;
        buffer = CreateBuffer(path.GetRawString(), &size);
        CubismMotion *tmpMotion = static_cast<CubismMotion *>(LoadMotion(
                buffer, size, name.GetRawString(), NULL, NULL, _modelSetting, group, i, _motionConsistency));

        if (tmpMotion) {
            tmpMotion->SetEffectIds(_eyeBlinkIds, _lipSyncIds);

            if (_motions[name] != NULL) {
                ACubismMotion::Delete(_motions[name]);
            }
            _motions[name] = tmpMotion;
        }

        DeleteBuffer(buffer, path.GetRawString());
    }
}

void LAppModel::ReleaseMotionGroup(const csmChar *group) const {
    const csmInt32 count = _modelSetting->GetMotionCount(group);
    for (csmInt32 i = 0; i < count; i++) {
        csmString voice = _modelSetting->GetMotionSoundFileName(group, i);
        if (strcmp(voice.GetRawString(), "") != 0) {
            csmString path = voice;
            path = _modelHomeDir + path;
        }
    }
}

/**
 * @brief すべてのモーションデータの解放
 *
 * すべてのモーションデータを解放する。
 */
void LAppModel::ReleaseMotions() {
    for (csmMap<csmString, ACubismMotion *>::const_iterator iter = _motions.Begin(); iter != _motions.End(); ++iter) {
        ACubismMotion::Delete(iter->Second);
    }

    _motions.Clear();
}

/**
 * @brief すべての表情データの解放
 *
 * すべての表情データを解放する。释放所有面部表情数据。
 */
void LAppModel::ReleaseExpressions() {
    for (csmMap<csmString, ACubismMotion *>::const_iterator iter = _expressions.Begin();
         iter != _expressions.End(); ++iter) {
        ACubismMotion::Delete(iter->Second);
    }

    _expressions.Clear();
}

void LAppModel::Update() {
    const csmFloat32 deltaTimeSeconds = LAppPal::GetDeltaTime();
    _userTimeSeconds += deltaTimeSeconds;

    // 更新随机动作冷却时间
    if (_randomActionCooldown > 0) {
        _randomActionCooldown -= deltaTimeSeconds;

        if (_debugMode && _randomActionCooldown <= 0) {
            qDebug() << "Random cooldown finished";
        }
    }

    _dragManager->Update(deltaTimeSeconds);
    _dragX = _dragManager->GetX();
    _dragY = _dragManager->GetY();

    // モーションによるパラメータ更新の有無
    csmBool motionUpdated = false;

    //-----------------------------------------------------------------
    _model->LoadParameters(); // 前回セーブされた状態をロード

    // 检测动作是否自然结束
    static bool wasMotionPlaying = false;
    bool isMotionPlaying = !_motionManager->IsFinished();
    // 如果动作从播放状态变为结束状态，设置随机冷却时间
    if (wasMotionPlaying && !isMotionPlaying) {
        // 动作自然结束，设置随机冷却时间
        SetRandomCooldown();
        if (_debugMode) {
            qDebug() << "Motion finished naturally, setting random cooldown";
        }
    }
    wasMotionPlaying = isMotionPlaying;

    if (_motionManager->IsFinished()) {
        // 只有在冷却时间结束后才播放空闲动作
        if (_randomActionCooldown <= 0) {
            // モーションの再生がない場合、待機モーションの中からランダムで再生する
            StartRandomMotion(MotionGroupIdle, PriorityIdle);
            // SetRandomExpressionEx();
        } else if (_debugMode) {
            if (_randomActionCooldown > 0) {
                // qDebug() << "Skipping idle motion - random cooldown:" << _randomActionCooldown;
            }
        }
    } else {
        motionUpdated = _motionManager->UpdateMotion(_model, deltaTimeSeconds); // モーションを更新
    }
    _model->SaveParameters(); // 状態を保存
    //-----------------------------------------------------------------

    // 不透明度
    _opacity = _model->GetModelOpacity();

    // まばたき
    if (!motionUpdated) {
        if (_eyeBlink != NULL) {
            // メインモーションの更新がないとき
            _eyeBlink->UpdateParameters(_model, deltaTimeSeconds); // 目パチ
        }
    }

    if (_expressionManager != NULL) {
        _expressionManager->UpdateMotion(_model, deltaTimeSeconds); // 表情でパラメータ更新（相対変化）
    }

    // ドラッグによる変化
    // ドラッグによる顔の向きの調整
    _model->AddParameterValue(_idParamAngleX, _dragX * 30); // -30から30の値を加える
    _model->AddParameterValue(_idParamAngleY, _dragY * 30);
    _model->AddParameterValue(_idParamAngleZ, _dragX * _dragY * -30);

    // ドラッグによる体の向きの調整
    _model->AddParameterValue(_idParamBodyAngleX, _dragX * 10); // -10から10の値を加える

    // ドラッグによる目の向きの調整
    _model->AddParameterValue(_idParamEyeBallX, _dragX); // -1から1の値を加える
    _model->AddParameterValue(_idParamEyeBallY, _dragY);

    // 呼吸など
    if (_breath != NULL) {
        _breath->UpdateParameters(_model, deltaTimeSeconds);
    }

    // 物理演算の設定
    if (_physics != NULL) {
        _physics->Evaluate(_model, deltaTimeSeconds);
    }

    // リップシンクの設定 口型设定
    if (_lipSync) {
        // リアルタイムでリップシンクを行う場合、システムから音量を取得して0〜1の範囲で値を入力します。
        csmFloat32 value = 0.0f;

        // 状態更新/RMS値取得
        _wavFileHandler.Update(deltaTimeSeconds);
        value = _wavFileHandler.GetRms();

        for (csmUint32 i = 0; i < _lipSyncIds.GetSize(); ++i) {
            _model->AddParameterValue(_lipSyncIds[i], value, 0.8f);
        }
    }

    // ポーズの設定
    if (_pose != NULL) {
        _pose->UpdateParameters(_model, deltaTimeSeconds);
    }

    _model->Update();
}

CubismMotionQueueEntryHandle LAppModel::StartMotion(const csmChar *group, csmInt32 no, csmInt32 priority,
                                                    ACubismMotion::FinishedMotionCallback onFinishedMotionHandler,
                                                    ACubismMotion::BeganMotionCallback onBeganMotionHandler) {
    if (priority == PriorityForce) {
        _motionManager->SetReservePriority(priority);
    } else if (!_motionManager->ReserveMotion(priority)) {
        if (_debugMode) {
            LAppPal::PrintLogLn("[APP]can't start motion.");
            qDebug() << "can't start motion";
        }
        return InvalidMotionQueueEntryHandleValue;
    }

    const csmString fileName = _modelSetting->GetMotionFileName(group, no);

    // ex) idle_0
    csmString name = Utils::CubismString::GetFormatedString("%s_%d", group, no);
    CubismMotion *motion = static_cast<CubismMotion *>(_motions[name.GetRawString()]);
    csmBool autoDelete = false;

    if (motion == NULL) {
        csmString path = fileName;
        path = _modelHomeDir + path;

        csmByte *buffer;
        csmSizeInt size;
        buffer = CreateBuffer(path.GetRawString(), &size);
        motion = static_cast<CubismMotion *>(LoadMotion(buffer, size, NULL, onFinishedMotionHandler,
                                                        onBeganMotionHandler, _modelSetting, group, no,
                                                        _motionConsistency));

        if (motion) {
            motion->SetEffectIds(_eyeBlinkIds, _lipSyncIds);
            autoDelete = true; // 終了時にメモリから削除
        } else {
            CubismLogError("Can't start motion %s .", path.GetRawString());
            qWarning() << "Can't start motion" << path.GetRawString();
            // ロードできなかったモーションのReservePriorityをリセットする
            _motionManager->SetReservePriority(PriorityNone);
            DeleteBuffer(buffer, path.GetRawString());
            return InvalidMotionQueueEntryHandleValue;
        }

        DeleteBuffer(buffer, path.GetRawString());
    } else {
        motion->SetBeganMotionHandler(onBeganMotionHandler);
        motion->SetFinishedMotionHandler(onFinishedMotionHandler);
    }

    // voice
    csmString voice = _modelSetting->GetMotionSoundFileName(group, no);
    if (strcmp(voice.GetRawString(), "") != 0) {
        csmString path = voice;
        path = _modelHomeDir + path;
        _wavFileHandler.Start(path);
    }

    if (_debugMode) {
        LAppPal::PrintLogLn("[APP]start motion: [%s_%d]", group, no);
        qDebug() << "start motion[" << group << no << "]";
    }
    return _motionManager->StartMotionPriority(motion, autoDelete, priority);
}

CubismMotionQueueEntryHandle LAppModel::StartRandomMotion(const csmChar *group, csmInt32 priority,
                                                          ACubismMotion::FinishedMotionCallback onFinishedMotionHandler,
                                                          ACubismMotion::BeganMotionCallback onBeganMotionHandler) {
    // 如果已经有动作在播放，且不是强制优先级，则不播放新的空闲动作
    if (priority == PriorityIdle && !_motionManager->IsFinished()) {
        if (_debugMode) {
            qDebug() << "Skipping idle motion - another motion is already playing";
        }
        return InvalidMotionQueueEntryHandleValue;
    }

    // 为了保持向后兼容性，如果指定了特定组，仍然使用原有逻辑
    if (group != NULL && strcmp(group, "") != 0 && strcmp(group, "Idle") != 0) {
        // 使用原有逻辑
        if (_modelSetting->GetMotionCount(group) == 0) {
            return InvalidMotionQueueEntryHandleValue;
        }
        csmInt32 no = rand() % _modelSetting->GetMotionCount(group);
        return StartMotion(group, no, priority, onFinishedMotionHandler, onBeganMotionHandler);
    }

    // 如果没有指定组或指定了Idle组，使用统一列表
    return StartRandomMotionEx(priority, onFinishedMotionHandler, onBeganMotionHandler);
}

void LAppModel::DoDraw() {
    if (_model == NULL) {
        return;
    }

    GetRenderer<Rendering::CubismRenderer_OpenGLES2>()->DrawModel();
}

void LAppModel::Draw(CubismMatrix44 &matrix) {
    if (_model == NULL) {
        return;
    }

    matrix.MultiplyByMatrix(_modelMatrix);

    GetRenderer<Rendering::CubismRenderer_OpenGLES2>()->SetMvpMatrix(&matrix);

    DoDraw();
}

csmBool LAppModel::HitTest(const csmChar *hitAreaName, csmFloat32 x, csmFloat32 y) {
    // 透明時は当たり判定なし。
    if (_opacity < 1) {
        return false;
    }
    const csmInt32 count = _modelSetting->GetHitAreasCount();
    for (csmInt32 i = 0; i < count; i++) {
        if (strcmp(_modelSetting->GetHitAreaName(i), hitAreaName) == 0) {
            const CubismIdHandle drawID = _modelSetting->GetHitAreaId(i);
            return IsHit(drawID, x, y);
        }
    }
    return false; // 存在しない場合はfalse
}

// 播放表情
void LAppModel::SetExpression(const csmChar *expressionID) {
    ACubismMotion *motion = _expressions[expressionID];
    if (_debugMode) {
        LAppPal::PrintLogLn("[APP]expression: [%s]", expressionID);
        qDebug() << "expression[" << expressionID << "]";
    }

    if (motion != NULL) {
        _expressionManager->StartMotion(motion, false);
    } else {
        if (_debugMode) {
            LAppPal::PrintLogLn("[APP]expression[%s] is null ", expressionID);
            qDebug() << "expression[" << expressionID << "] is null ";
        }
    }
}

void LAppModel::SetRandomExpression() {
    if (_expressions.GetSize() == 0) {
        return;
    }

    csmInt32 no = rand() % _expressions.GetSize();
    csmMap<csmString, ACubismMotion *>::const_iterator map_ite;
    csmInt32 i = 0;
    for (map_ite = _expressions.Begin(); map_ite != _expressions.End(); map_ite++) {
        if (i == no) {
            csmString name = (*map_ite).First;
            SetExpression(name.GetRawString());
            return;
        }
        i++;
    }
}

void LAppModel::ReloadRenderer() {
    DeleteRenderer();

    CreateRenderer();

    SetupTextures();
}

void LAppModel::SetupTextures() {
    for (csmInt32 modelTextureNumber = 0; modelTextureNumber < _modelSetting->GetTextureCount(); modelTextureNumber++) {
        // テクスチャ名が空文字だった場合はロード・バインド処理をスキップ
        if (strcmp(_modelSetting->GetTextureFileName(modelTextureNumber), "") == 0) {
            continue;
        }

        // OpenGLのテクスチャユニットにテクスチャをロードする
        csmString texturePath = _modelSetting->GetTextureFileName(modelTextureNumber);
        texturePath = _modelHomeDir + texturePath;

        LAppTextureManager::TextureInfo *texture = LAppDelegate::GetInstance()->GetTextureManager()->CreateTextureFromPngFile(
                texturePath.GetRawString());
        const csmInt32 glTextueNumber = texture->id;

        // OpenGL
        GetRenderer<Rendering::CubismRenderer_OpenGLES2>()->BindTexture(modelTextureNumber, glTextueNumber);
    }

#ifdef PREMULTIPLIED_ALPHA_ENABLE
    GetRenderer<Rendering::CubismRenderer_OpenGLES2>()->IsPremultipliedAlpha(true);
#else
    GetRenderer<Rendering::CubismRenderer_OpenGLES2>()->IsPremultipliedAlpha(false);
#endif
}

void LAppModel::MotionEventFired(const csmString &eventValue) {
    CubismLogInfo("%s is fired on LAppModel!!", eventValue.GetRawString());
}

Csm::Rendering::CubismOffscreenSurface_OpenGLES2 &LAppModel::GetRenderBuffer() {
    return _renderBuffer;
}

csmBool LAppModel::HasMocConsistencyFromFile(const csmChar *mocFileName) {
    CSM_ASSERT(strcmp(mocFileName, ""));

    csmByte *buffer;
    csmSizeInt size;

    csmString path = mocFileName;
    path = _modelHomeDir + path;

    buffer = CreateBuffer(path.GetRawString(), &size);

    csmBool consistency = CubismMoc::HasMocConsistencyFromUnrevivedMoc(buffer, size);
    if (!consistency) {
        CubismLogInfo("Inconsistent MOC3.");
    } else {
        CubismLogInfo("Consistent MOC3.");
    }

    DeleteBuffer(buffer);

    return consistency;
}

// 加载额外文件
void LAppModel::LoadExtraFiles() {
    if (!_extraFileManager) {
        return;
    }

    // 加载额外文件
    _extraFileManager->loadExtraFiles(QString::fromUtf8(_modelHomeDir.GetRawString()));
    if (_debugMode) {
        auto expressions = _extraFileManager->getAvailableExpressions();
        auto motions = _extraFileManager->getAvailableMotions();
        qDebug() << "Loaded" << expressions.size() << "extra expressions and"
                 << motions.size() << "extra motions";

        // 输出具体文件名
        if (!expressions.isEmpty()) {
            qDebug() << "Available extra expressions:" << expressions;
        }
        if (!motions.isEmpty()) {
            qDebug() << "Available extra motions:" << motions;
        }
    }
}

// 增强版表情播放 - 优先使用额外文件，回退到原有文件
void LAppModel::SetExpressionEx(const csmChar *expressionID) {
    if (_debugMode) {
        qDebug() << "=== SetExpressionEx called with:" << expressionID << "===";
    }

    // 首先尝试播放额外表情
    if (_extraFileManager && _expressionManager) {
        if (_debugMode) {
            qDebug() << "ExtraFileManager and ExpressionManager are available";
        }

        QByteArray data = _extraFileManager->getExpressionData(QString::fromUtf8(expressionID));
        if (!data.isEmpty()) {
            if (_debugMode) {
                qDebug() << "Found extra expression data, size:" << data.size();
            }
            // 尝试直接使用 CubismExpressionMotion 加载
            try {
                // 加载表情数据
                ACubismMotion *motion = LoadExpression(
                        reinterpret_cast<const csmByte *>(data.constData()),
                        data.size(),
                        expressionID);

                if (motion) {
                    if (_debugMode) {
                        qDebug() << "Successfully loaded expression motion, starting playback...";
                    }

                    // 启动表情
                    _expressionManager->StartMotion(motion, true); // autoDelete = true

                    if (_debugMode) {
                        qDebug() << "Playing extra expression:" << expressionID;
                    }
                    return;
                } else {
                    if (_debugMode) {
                        qDebug() << "LoadExpression returned NULL for:" << expressionID;
                    }
                }
            }
            catch (const std::exception &e) {
                if (_debugMode) {
                    qDebug() << "Exception while loading expression:" << e.what();
                }
            }
        } else {
            if (_debugMode) {
                qDebug() << "No extra expression data found for:" << expressionID;
            }
        }
    } else {
        if (_debugMode) {
            if (!_extraFileManager)
                qDebug() << "ExtraFileManager is NULL";
            if (!_expressionManager)
                qDebug() << "ExpressionManager is NULL";
        }
    }

    // 如果额外表情不存在，回退到原有表情
    if (_debugMode) {
        qDebug() << "Falling back to original expression system for:" << expressionID;
    }
    SetExpression(expressionID);
}

// 直接播放额外表情
void LAppModel::PlayExtraExpressionDirect(const csmChar *expressionName) {
    if (!_extraFileManager || !_expressionManager) {
        return;
    }

    QByteArray data = _extraFileManager->getExpressionData(QString::fromUtf8(expressionName));
    if (data.isEmpty()) {
        if (_debugMode) {
            qDebug() << "Extra expression not found:" << expressionName;
        }
        return;
    }

    ACubismMotion *motion = LoadExpression(
            reinterpret_cast<const csmByte *>(data.constData()),
            data.size(),
            expressionName);

    if (motion) {
        _expressionManager->StartMotion(motion, true);
        if (_debugMode) {
            qDebug() << "Playing extra expression:" << expressionName;
        }
    }
}

// 获取所有表情（包括原有的和额外的）
QVector<QString> LAppModel::GetAllExpressions() const {
    QVector<QString> expressions;
    // 添加原有表情 - 使用 const 迭代器
    for (auto it = _expressions.Begin(); it != _expressions.End(); ++it) {
        expressions.append(QString::fromUtf8(it->First.GetRawString()));
    }

    // 添加额外表情
    if (_extraFileManager) {
        auto extraExpressions = _extraFileManager->getAvailableExpressions();
        for (const QString &expr: extraExpressions) {
            if (!expressions.contains(expr)) {
                expressions.append(expr);
            }
        }
    }

    return expressions;
}

// 增强版随机表情播放 - 从所有表情（包括额外的）中随机选择
void LAppModel::SetRandomExpressionEx() {
    if (_debugMode) {
        qDebug() << "=== SetRandomExpressionEx called ===";
    }

    auto allExpressions = GetAllExpressions();
    if (_debugMode) {
        qDebug() << "Total expressions available:" << allExpressions.size();
        qDebug() << "All expressions:" << allExpressions;
    }

    if (allExpressions.isEmpty()) {
        if (_debugMode) {
            qDebug() << "No expressions available";
        }
        return;
    }
    // 随机选择一个表情
    int randomIndex = rand() % allExpressions.size();
    QString randomExpression = allExpressions[randomIndex];

    if (_debugMode) {
        qDebug() << "Selected random expression:" << randomExpression;
    }

    // 使用增强版表情播放
    SetExpressionEx(randomExpression.toUtf8().constData());
}

// 停止所有动作并清理
void LAppModel::StopAndClearAllMotions() {
    if (_motionManager) {
        _motionManager->StopAllMotions();
        // 重置保留优先级，避免后续动作无法启动
        _motionManager->SetReservePriority(PriorityNone);
    }

    if (_expressionManager) {
        _expressionManager->StopAllMotions();
    }
    // 如果是强制停止动作，也设置随机冷却时间
    SetRandomCooldown();
    qDebug() << "Clearing all motions & expressions. Done";
}

QVector<QString> LAppModel::GetAllMotions() const {
    QVector<QString> allMotions;

    // 添加原有动作
    for (csmMap<csmString, ACubismMotion *>::const_iterator iter = _motions.Begin(); iter != _motions.End(); ++iter) {
        allMotions.append(QString::fromUtf8(iter->First.GetRawString()));
    }

    // 添加额外动作
    if (_extraFileManager) {
        auto extraMotions = _extraFileManager->getAvailableMotions();
        for (const QString &motion: extraMotions) {
            if (!allMotions.contains(motion)) {
                allMotions.append(motion);
            }
        }
    }

    return allMotions;
}

CubismMotionQueueEntryHandle LAppModel::StartMotionByName(const csmChar *motionName, csmInt32 priority,
                                                          ACubismMotion::FinishedMotionCallback onFinishedMotionHandler,
                                                          ACubismMotion::BeganMotionCallback onBeganMotionHandler) {
    if (_debugMode) {
        qDebug() << "=== StartMotionByName called:" << motionName << "with priority:" << priority << "===";
        qDebug() << "Current motion finished:" << _motionManager->IsFinished();
    }
    // 如果是非空闲动作，设置随机冷却时间
    if (priority != PriorityIdle) {
        SetRandomCooldown();
    }
    // 首先检查是否是原有动作
    csmString motionKey(motionName);
    if (_motions[motionKey] != NULL) {
        if (_debugMode) {
            qDebug() << "Found in original motions, playing:" << motionName;
        }

        ACubismMotion *motion = _motions[motionKey];
        motion->SetBeganMotionHandler(onBeganMotionHandler);
        motion->SetFinishedMotionHandler(onFinishedMotionHandler);

        // 简化优先级处理：直接尝试播放，让动作管理器自己决定
        // 对于空闲动作，如果已经有动作在播放，就不播放
        if (priority == PriorityIdle && !_motionManager->IsFinished()) {
            if (_debugMode) {
                qDebug() << "Skipping idle motion - another motion is already playing";
            }
            return InvalidMotionQueueEntryHandleValue;
        }

        // 对于强制优先级，设置保留优先级
        if (priority == PriorityForce) {
            _motionManager->SetReservePriority(priority);
        }

        // 直接尝试播放，不检查ReserveMotion
        return _motionManager->StartMotionPriority(motion, false, priority);
    }

    // 然后检查额外动作
    if (_extraFileManager) {
        QByteArray data = _extraFileManager->getMotionData(QString::fromUtf8(motionName));
        if (!data.isEmpty()) {
            if (_debugMode) {
                qDebug() << "Found in extra motions, loading:" << motionName;
            }

            // 简化优先级处理
            if (priority == PriorityIdle && !_motionManager->IsFinished()) {
                if (_debugMode) {
                    qDebug() << "Skipping idle motion - another motion is already playing";
                }
                return InvalidMotionQueueEntryHandleValue;
            }

            if (priority == PriorityForce) {
                _motionManager->SetReservePriority(priority);
            }

            CubismMotion *motion = static_cast<CubismMotion *>(LoadMotion(
                    reinterpret_cast<const csmByte *>(data.constData()),
                    data.size(),
                    motionName,
                    onFinishedMotionHandler,
                    onBeganMotionHandler,
                    NULL,
                    "Extra",
                    0,
                    _motionConsistency));

            if (motion) {
                motion->SetEffectIds(_eyeBlinkIds, _lipSyncIds);
                CubismMotionQueueEntryHandle handle = _motionManager->StartMotionPriority(motion, true, priority);

                if (_debugMode) {
                    qDebug() << "Playing extra motion:" << motionName;
                }
                return handle;
            }
        }
    }

    if (_debugMode) {
        qDebug() << "Motion not found:" << motionName;
    }
    return InvalidMotionQueueEntryHandleValue;
}

CubismMotionQueueEntryHandle LAppModel::StartRandomMotionEx(csmInt32 priority,
                                                            ACubismMotion::FinishedMotionCallback
                                                            onFinishedMotionHandler,
                                                            ACubismMotion::BeganMotionCallback onBeganMotionHandler) {
    auto allMotions = GetAllMotions();
    if (allMotions.isEmpty()) {
        if (_debugMode) {
            qDebug() << "No motions available";
        }
        return InvalidMotionQueueEntryHandleValue;
    }

    // 随机选择一个动作
    int randomIndex = rand() % allMotions.size();
    QString randomMotion = allMotions[randomIndex];

    if (_debugMode) {
        qDebug() << "Playing random motion:" << randomMotion;
    }

    return StartMotionByName(randomMotion.toUtf8().constData(), priority, onFinishedMotionHandler,
                             onBeganMotionHandler);
}

bool LAppModel::HasMotion(const csmChar *motionName) const {
    // 检查原有动作
    csmString key(motionName);
    for (auto it = _motions.Begin(); it != _motions.End(); ++it) {
        if (it->First == key && it->Second != NULL) {
            return true;
        }
    }

    // 检查额外动作
    if (_extraFileManager) {
        QByteArray data = _extraFileManager->getMotionData(QString::fromUtf8(motionName));
        return !data.isEmpty();
    }

    return false;
}

// 检查是否存在表情
bool LAppModel::HasExpression(const csmChar *expressionID) const {
    // 检查原有表情 - 使用迭代器遍历查找
    csmString key(expressionID);
    for (auto it = _expressions.Begin(); it != _expressions.End(); ++it) {
        if (it->First == key && it->Second != NULL) {
            return true;
        }
    }

    // 检查额外表情
    if (_extraFileManager) {
        QByteArray data = _extraFileManager->getExpressionData(QString::fromUtf8(expressionID));
        return !data.isEmpty();
    }

    return false;
}
