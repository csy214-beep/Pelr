# Sources
*.c     text diff=cpp
*.cc    text diff=cpp
*.cxx   text diff=cpp
*.cpp   text diff=cpp
*.cpi   text diff=cpp
*.c++   text diff=cpp
*.hpp   text diff=cpp
*.h     text diff=cpp
*.h++   text diff=cpp
*.hh    text diff=cpp


# Compiled Object files
*.slo   binary
*.lo    binary
*.o     binary
*.obj   binary

# Precompiled Headers
*.gch   binary
*.pch   binary

# Compiled Dynamic libraries
*.so    binary
*.dylib binary
*.dll   binary

# Compiled Static libraries
*.lai   binary
*.la    binary
*.a     binary
*.lib   binary

# Executables
*.exe   binary
*.out   binary
*.app   binary

# 明确指定 C++ 文件为主要语言，并确保它们被统计
*.cpp linguist-language=C++
*.h linguist-language=C++
*.hpp linguist-language=C++
*.ui linguist-language=C++
*.qrc linguist-language=C++
*.qss linguist-language=C++
# 如果有的话，也可以加上 Qt 的 pro 或 pri 文件
*.pro linguist-language=C++
*.pri linguist-language=C++

# *.txt linguist-language=C++
# *.py linguist-language=C++
# *.pyw linguist-language=C++
# *.pyi linguist-language=C++

# 如果项目中有 Python 脚本（例如一些工具脚本），但不希望它们影响主语言统计，可以将其标记为“vendored”或“documentation”
# 假设你的 tools/ 目录下有一些 Python 脚本
# *.py linguist-vendored   # 标记为“vendored”代码，Linguist 将忽略其统计
# 或者直接忽略整个工具目录的语言统计
assets

# 对于确实需要被识别为 Python 的文件（虽然不是主语言），可以明确指定，但通常不需要为主项目设置
*.py linguist-language=Python

# 标记常见的二进制文件，防止它们被误判或计入统计
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
# Live2D 相关的资源文件，如果知道扩展名，也最好标记为 binary
# *.moc binary  # 如果有 Qt 的 moc 生成的文件

# 确保 Git 对文本文件进行正确的行尾符转换（可选但推荐）
* text=auto

docs/** linguist-vendored=true
scripts/** linguist-vendored=true

